    {
      "name": "New Folder",
      "item": [
        {
          "name": "0 - POST Seed 10 employees",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const employees = [",
                  "  { firstName: \"Marko\", lastName: \"Markovic\", department: \"QA\", salary: 85000 },",
                  "  { firstName: \"Nikola\", lastName: \"Nikolic\", department: \"DEVELOPMENT\", salary: 120000 },",
                  "  { firstName: \"Jovana\", lastName: \"Jovanovic\", department: \"HR\", salary: 78000 },",
                  "  { firstName: \"Milica\", lastName: \"Milic\", department: \"FINANCE\", salary: 95000 },",
                  "  { firstName: \"Petar\", lastName: \"Petrovic\", department: \"SALES\", salary: 88000 },",
                  "  { firstName: \"Ana\", lastName: \"Anic\", department: \"SUPPORT\", salary: 72000 },",
                  "  { firstName: \"Stefan\", lastName: \"Stefanovic\", department: \"MANAGEMENT\", salary: 150000 },",
                  "  { firstName: \"Luka\", lastName: \"Lukic\", department: \"IT\", salary: 110000 },",
                  "  { firstName: \"Sara\", lastName: \"Saric\", department: \"DEVOPS\", salary: 130000 },",
                  "  { firstName: \"Milan\", lastName: \"Milanovic\", department: \"PRODUCT\", salary: 140000 }",
                  "];",
                  "",
                  "const index = pm.info.iteration;",
                  "const employee = employees[index];",
                  "",
                  "const uniqueCode = \"EMP-\" + Date.now() + \"-\" + (index + 1);",
                  "",
                  "pm.variables.set(\"employeeCode\", uniqueCode);",
                  "pm.variables.set(\"firstName\", employee.firstName);",
                  "pm.variables.set(\"lastName\", employee.lastName);",
                  "pm.variables.set(\"department\", employee.department);",
                  "pm.variables.set(\"salary\", employee.salary);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeCode\": \"{{employeeCode}}\",\n  \"firstName\": \"{{firstName}}\",\n  \"lastName\": \"{{lastName}}\",\n  \"department\": \"{{department}}\",\n  \"salary\": {{salary}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "employees"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "1 - Create employee",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "if (pm.response.code === 201) {",
              "    const json = pm.response.json();",
              "    pm.collectionVariables.set('employeeId', json.id);",
              "    pm.collectionVariables.set('employeeCode', json.employeeCode);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
