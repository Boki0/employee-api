    {
      "name": "14 - Get salary analytics",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has salary analytics fields', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('averageSalary');",
              "    pm.expect(json).to.have.property('medianSalary');",
              "    pm.expect(json).to.have.property('salariesByDepartment');",
              "    pm.expect(json).to.have.property('topFivePaidEmployees');",
              "});"
            ]
