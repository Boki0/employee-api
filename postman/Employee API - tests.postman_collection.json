          "raw": "{\n  \"employeeCode\": \"EMP-{{$timestamp}}\",\n  \"firstName\": \"Pera\",\n  \"lastName\": \"Peric\",\n  \"department\": \"QA\",\n  \"salary\": 1500.00\n}"
