    {
      "name": "15 - Get audit logs",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is audit log array', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    pm.expect(json.length).to.be.greaterThan(0);",
              "});",
              "pm.test('Audit logs contain main actions', function () {",
              "    const actions = pm.response.json().map(log => log.action);",
              "    pm.expect(actions).to.include('EMPLOYEE_CREATED');",
              "    pm.expect(actions).to.include('EMPLOYEE_DETAILS_FETCHED');",
              "    pm.expect(actions).to.include('EMPLOYEES_SEARCHED');",
              "    pm.expect(actions).to.include('SALARY_UPDATED');",
              "    pm.expect(actions).to.include('SALARY_ANALYTICS_REQUESTED');",
              "});"
            ]
          }
        }
      ],
